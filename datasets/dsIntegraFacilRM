function createDataset (fields, constraints, sortFields) {
	try {
		var NOME_DATASERVER;
		var OBJETO;
		var PRIMARY_KEY
		var CODSISTEMA;
		var CAMPOS;
		var COLIGADA;
		var SENTENCA;
		var APLICACAO;
		var PARAMETER;
		var FILTRO;
		var TAMANHO_MINIMO;
		var SQLLIMIT;
		var XML;
		var TAMANHO_PRIMARYKEY;
		var ZOOM;
		var PROCESS;
		var REPORT;
		var FILE;
		var IDFV;
		var OPC = 1; // 0: DELETE, 1: READVIEW, 2: READRECORD, 3:SAVERECORD, 4: SQL, 5: EXECUTEPROCESSWITHXMLPARAMS, 6: WSREPORT, 9: EXECUTE_FV
		var OPC_DESCRICAO = "READVIEW";
		var SAV;
		var REC;
		var VIE;
		var SQL;
		var EXP;
		
		var xmlResultados = "";
		var novaConstraints = new Array();
		var RMS = new Array();
		var filters = {};
	
		for ( var x = 0; x < constraints.length; x++) {
			if ( constraints[x].fieldName.toUpperCase() == "DATASERVER" || constraints[x].fieldName.toUpperCase() == "NOME_DATASERVER" ) {
				NOME_DATASERVER = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "COLIGADA" ) {
				COLIGADA = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "SENTENCA" ) {
				SENTENCA = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "APLICACAO" ) {
				APLICACAO = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "CODSISTEMA" ) {
				CODSISTEMA = constraints[x].initialValue;	
				
			} else if ( constraints[x].fieldName.toUpperCase() == "PARAMETER" ) {
				PARAMETER = constraints[x].initialValue;
				PARAMETER = replaceAll(PARAMETER, "|", ";");
				
			} else if ( constraints[x].fieldName.toUpperCase() == "FILTRO" ) {
				FILTRO = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "XML" ) {
				XML = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "TAMANHO_PRIMARYKEY" ) {
				TAMANHO_PRIMARYKEY = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "OBJETO" || constraints[x].fieldName.toUpperCase() == "TABELA" ) {
				OBJETO = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "PRIMARY_KEY" ) {
				PRIMARY_KEY = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "CAMPOS" ) {
				CAMPOS = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "EXP" ) {
				OPC = 5;
				OPC_DESCRICAO = "EXECUTEPROCESSWITHXMLPARAMS";
				EXP = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "SQL" ) {
				OPC = 4;
				OPC_DESCRICAO = "SQL";
				SQL = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "SAV" ) {
				OPC = 3;
				OPC_DESCRICAO = "SAVERECORD";
				SAV = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "REC" ) {
				OPC = 2;
				OPC_DESCRICAO = "READRECORD";
				REC = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "VIE" ) {
				OPC = 1;
				OPC_DESCRICAO = "READVIEW";
				VIE = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "OPC" ) {
				OPC = parseInt(constraints[x].initialValue);
				switch (OPC ) {
					case 1:
						OPC_DESCRICAO = "READVIEW";
						break;
						
					case 2:
						OPC_DESCRICAO = "READRECORD";
						break;
						
					case 3:
						OPC_DESCRICAO = "SAVERECORD";
						break;
						
					case 4:
						OPC_DESCRICAO = "SQL";
						break;
						
					case 5:
						OPC_DESCRICAO = "EXECUTEPROCESSWITHXMLPARAMS";
						break;
						
					case 6:
						OPC_DESCRICAO = "WSREPORT";
						break;
						
					case 7:
						OPC_DESCRICAO = "SQL_TOXML_TOJSON";
						break;
						
					case 8:
						OPC_DESCRICAO = "READVIEW_TOXML_TOJSON";
						break;
						
					case 9:
						OPC_DESCRICAO = "EXECUTE_FV";
						break;
				}
				
			} else if ( constraints[x].fieldName.toUpperCase() == "TAMANHO_MINIMO" ) {
				TAMANHO_MINIMO = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "SQLLIMIT" ) {
				SQLLIMIT = constraints[x].initialValue;
				continue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "RMSCONTEXT" || constraints[x].fieldName.toUpperCase() == "RMSFILTER" ) {
				RMS.push(constraints[x]);
				
			} else if ( constraints[x].fieldName.toUpperCase() == "ZOOM" ) {
				ZOOM = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "PROCESS" ) {
				PROCESS = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "REPORT" ) {
				REPORT = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "FILE" ) {
				FILE = constraints[x].initialValue;
				
			} else if ( constraints[x].fieldName.toUpperCase() == "IDFV" ) {
				IDFV = constraints[x].initialValue;
				
			} else {
				novaConstraints.push(constraints[x]);
				log.info("######### [DSINTEGRAFACILRM] CONSTRAINTS: " + constraints[x].fieldName.toUpperCase() + " - " + constraints[x].initialValue);
			}
		}
		
		zoomConstraints = new Array();
		if ( ZOOM && fields && fields.length > 0 && OPC != 4 ) {
			for (var x = 0; x < novaConstraints.length; x++) {
				for (var y = 0;y < fields.length;y++) {
					if (novaConstraints[x].fieldName.toUpperCase() != fields[y]) {
						zoomConstraints.push(DatasetFactory.createConstraint(fields[y], novaConstraints[x].initialValue, novaConstraints[x].finalValue, ConstraintType.SHOULD));
					}
				}
			}
			
		} else if ( ZOOM && OPC == 4 && PARAMETER ) {
			for (var x = 0; x < novaConstraints.length; x++) {
				PARAMETER = PARAMETER.replace('@', novaConstraints[x].initialValue);
			}
			novaConstraints = new Array();
		}
		
		for ( var x = 0; x < RMS.length; x++) {
			novaConstraints.push(RMS[x]);
		}
		
		for (var x = 0; x < zoomConstraints.length; x++) {
			novaConstraints.push(zoomConstraints[x]);
		}
		
		log.info("######### [DSINTEGRAFACILRM] ESCOHIDA A OPERAÇÃO: " + OPC + " ( " + OPC_DESCRICAO + " )");
		
		/**
		 * CONDIÇÕES CRIADAS PARA MANTER COMPATIBILIDADE COM O DATASET UTILIZADO EM OUTROS PROCESSOS, CASO NÃO SEJA ENVIADA A CONSTRAINT COM A LISTA DE CAMPOS É UTILIZADA A LISTA DOS CAMPOS RECEBIDAS EM FIELDS.
		 */
		
		if ( !CAMPOS && !fields ) {
			log.info("######### [DSINTEGRAFACILRM] POR FAVOR UTILIZE A CONSTRAINT DE CAMPOS OU PARAMETRO FIELDS PARA PASSAR OS CAMPOS A SEREM RETORNADOS.");
			
		} else if (!CAMPOS && fields) {
			if (fields.length > 1) {
				CAMPOS = fields.join('&');
				
			} else {
				CAMPOS = fields[0];
			}
			
		} else if ( CAMPOS && fields ) {
			log.info("######### [DSINTEGRAFACILRM] EVITE UTILZIAR A CONSTRAINT DE CAMPOS E O PARAMETRO FIELDS PARA PASSAR OS CAMPOS A SEREM RETORNADOS, QUANDO PASSADO OS DOIS APENAS A CONSTRAINT SERÁ UTILZADA.");
		}
		
		/**
		 * MANTENDO FUNÇÃO DE BUSCAR DO DATASET DSINTEGRADOR OS USUÁRIOS E SENHAS DE INTEGRAÇÃO
		 */
		
		var integration = getPasswordUserIntegration();
		var usuario = integration.USUARIO;
		var senha = integration.SENHA;
		
		if ( OPC == 4 ) {
			if ( !PARAMETER ) {
				PARAMETER = "";
			}
			
			for (i = 0; i < novaConstraints.length; i++) {
				if (PARAMETER == "") {
					PARAMETER += constraints[i].fieldName + "=" + constraints[i].initialValue;
					
				} else {
					PARAMETER += ";" + constraints[i].fieldName + "=" + constraints[i].initialValue;
				}
			}
			
		} else {
			filters = parseConstraints(novaConstraints, true, OBJETO);
		}
		
		/**
		 * CONDIÇÕES CRIADAS PARA MANTER COMPATIBILIDADE COM O DATASET UTILIZADO EM OUTROS PROCESSOS, CRIA O CONTEXT E O FILTER, MESMO QUANDO NÃO ENVIADAS AS CONSTRAINT RMSCONTEXT E RMSFILTER.
		 */
		
		if ( filters.context == "" && COLIGADA ) {
			/*filters.context = "CODCOLIGADA=" + COLIGADA + ";CODUSUARIO=" + usuario;*/
			filters.context = "CODCOLIGADA=1" + ";CODUSUARIO=" + usuario;
		}
		
		log.info("######### [DSINTEGRAFACILRM] CONTEXTO GERADO PARA CONSULTA: " + filters.context);
		if ( FILTRO ) {
			if (filters.filter == "") {
				filters.filter = "(" + replaceAll(FILTRO, '"', "'") + ")";
				
			} else {
				filters.filter = "(" + filters.filter + ") AND (" + replaceAll(FILTRO, '"', "'") + ")";
			}
		}
		
		log.info("######### [DSINTEGRAFACILRM] FILTRO GERADO PARA CONSULTA: " + filters.filter);
		switch (OPC) {
			case 0:
				if ( !NOME_DATASERVER || !PRIMARY_KEY ) {
					throw "POR FAVOR REVEJA AS CONSTRAINTS, CONSTRAINT OBRIGATORIA (NOME_DATASERVER OU PRIMARY_KEY) FALTANDO.";
				}
				
				log.info("######### [DSINTEGRAFACILRM] EXECUTANDO PROCESSO DE DELEÇÃO DE REGISTRO");
				var dataset = DatasetBuilder.newDataset();
				dataset.addColumn("RETORNO");
				dataset.addColumn("DATASERVER");
				dataset.addColumn("PRIMARY_KEY");
				dataset.addColumn("CONTEXT");
				var result = dcDeleteRecordByKey(NOME_DATASERVER, filters.context, usuario, senha, PRIMARY_KEY);
				log.info("######### [DSINTEGRAFACILRM] OPC 0 - RESULTADO: " + result);
				
				if ( result.toString().toUpperCase().indexOf('EXCLUSÃO DE REGISTRO(S) REALIZADO COM SUCESSO') != -1 ) {
					var linha = new Array();
					linha.push(result.toString());
					linha.push(NOME_DATASERVER);
					linha.push(PRIMARY_KEY);
					linha.push(filters.context);
					dataset.addRow(linha);
					
					return dataset;
				} 
				
				throw result.toString()
				
			case 1:
				if (!NOME_DATASERVER || !OBJETO || !CAMPOS) {
					throw "POR FAVOR REVEJA AS CONSTRAINTS, CONSTRAINT OBRIGATORIA (NOME_DATASERVER, OBJETO OU CAMPO) FALTANDO.";
				}
				
				log.info("######### [DSINTEGRAFACILRM] EXECUTANDO PROCESSO DE LEITURA");
				var xmlResultados = dcReadView(NOME_DATASERVER, filters.context, usuario, senha, filters.filter);
				var dataset = DatasetBuilder.newDataset();
				if (!xmlResultados[OBJETO][0]) {
					throw "NÃO FORAM ENCONTRADO OS DADOS NA CONSULTA.";
				}
				
				var colunas = [];
				if (CAMPOS.indexOf(",") > -1) {
					colunas = CAMPOS.split(",");
				} else if (CAMPOS.indexOf(";") > -1) {
					colunas = CAMPOS.split(";");
				} else if (CAMPOS.indexOf("&") > -1) {
					colunas = CAMPOS.split("&");
				} else {
					colunas.push(CAMPOS);
				}
				
				for (var i = 0; i < colunas.length; i++) {
					dataset.addColumn(colunas[i]);
				}
				
				log.info("######### [DSINTEGRAFACILRM] PREPARANDO COLUNAS PADRAO: NOME_DATASERVER, OBJETO, CAMPOS, RMSFILTER, RMSCONTEXT, XML");
				dataset.addColumn("DATASERVER");
				dataset.addColumn("OBJETO");
				dataset.addColumn("CAMPOS");
				dataset.addColumn("RMSFILTER");
				dataset.addColumn("RMSCONTEXT");
				log.info("######### [DSINTEGRAFACILRM] ADICIONANDO LINHAS: ");
				log.info("######### SQLLIMIT " + SQLLIMIT);
				
				for (var i = 0; i < xmlResultados[OBJETO].length(); i++) {
					var linha = new Array();
					for (var j = 0;j < colunas.length;j++) {
						linha.push(xmlResultados[OBJETO][i][colunas[j]].toString());
					}
					linha.push(NOME_DATASERVER);
					linha.push(OBJETO);
					linha.push(CAMPOS);
					linha.push(filters.filter);
					linha.push(filters.context);
					dataset.addRow(linha);
					if (SQLLIMIT && i >= SQLLIMIT) {
						break;
					}
				}
				log.info("######### [DSINTEGRAFACILRM] DATASET CRIADO COM SUCESSO");
				
				return dataset;
				
			case 2:
				if ( !NOME_DATASERVER || !CAMPOS || !PRIMARY_KEY ) {
					throw "POR FAVOR REVEJA AS CONSTRAINTS, CONSTRAINT OBRIGATORIA (NOME_DATASERVER, PRIMARY_KEY OU CAMPO) FALTANDO.";
				}
				log.info("######### [DSINTEGRAFACILRM] EXECUTANDO PROCESSO DE LEITURA");
				var xmlResultados = dcReadRecord(NOME_DATASERVER, filters.context, usuario, senha, PRIMARY_KEY);
				var dataset = DatasetBuilder.newDataset();
				
				var colunas = [];
				if (CAMPOS.indexOf(",") > -1) {
					colunas = CAMPOS.split(",");
				} else if (CAMPOS.indexOf(";") > -1) {
					colunas = CAMPOS.split(";");
				} else if (CAMPOS.indexOf("&") > -1) {
					colunas = CAMPOS.split("&");
				} else {
					colunas.push(CAMPOS);
				}
				
				var objXML = {};
				for ( var i = 0; i < colunas.length; i++) {
					if ( colunas[i].indexOf(".") > -1 ) {
						var indice = colunas[i].indexOf(".");
						var tabela = colunas[i].substring(0, indice);
						var attr = colunas[i].substring(indice + 1);
						if ( objXML[tabela] ) {
							objXML[tabela].push(attr);
							
						} else {
							objXML[tabela] = new Array();
							objXML[tabela].push(attr);
						}
						
					} else {
						throw "POR FAVOR REVEJA AS OS CAMPOS PASSADOS NÃO FOI IDENTIFICADO O ELEMENTO DO ATIRIBUTO.";
					}
				}
				
				for ( var tabela in objXML) {
					var qtd = xmlResultados[tabela].length(); //log.info("######### [DSINTEGRAFACILRM] QTD DE REGISTROS ENCONTRADO NA TABELA " + tabela + ": " + qtd);
					for ( var h = 0;h < qtd;h++) {
						for ( var i = 0; i < objXML[tabela].length; i++) {
							if ( qtd > 1 ) { //		log.info("######### [DSINTEGRAFACILRM] ADICIONANDO COLUNA: " + objXML[tabela][i] + "_" + (h + 1));
								dataset.addColumn(objXML[tabela][i] + "_" + (h + 1));
								
							} else {
								dataset.addColumn(objXML[tabela][i]); //		log.info("######### [DSINTEGRAFACILRM] ADICIONANDO COLUNA: " + objXML[tabela][i]);
							}
						}
					}
				}
				
				log.info("######### [DSINTEGRAFACILRM] PREPARANDO COLUNAS PADRAO: NOME_DATASERVER, OBJETO, CAMPOS, RMSFILTER, RMSCONTEXT, XML");
				dataset.addColumn("DATASERVER");
				dataset.addColumn("CAMPOS");
				dataset.addColumn("PRIMARY_KEY");
				dataset.addColumn("RMSCONTEXT");
				dataset.addColumn("XML");
				log.info("######### [DSINTEGRAFACILRM] ADICIONANDO LINHAS: ");
				var linha = new Array();
				var flag = false;
				for ( var tabela in objXML) {
					var qtd = xmlResultados[tabela].length();
					for (var h = 0;h < qtd;h++) {
						for (var i = 0; i < objXML[tabela].length; i++) {
							linha.push(xmlResultados[tabela][h][objXML[tabela][i]].toString());
							flag = true;
						}
					}
				}
				
				if ( !flag ) {
					throw "NÃO FORAM ENCONTRADO OS DADOS NA CONSULTA.";
				}
				
				linha.push(NOME_DATASERVER);
				linha.push(CAMPOS);
				linha.push(PRIMARY_KEY);
				linha.push(filters.context);
				linha.push(XML);
				dataset.addRow(linha);
				log.info("######### [DSINTEGRAFACILRM] DATASET CRIADO COM SUCESSO");
				
				return dataset;
				
			case 3:
				if ( !NOME_DATASERVER || !XML || !TAMANHO_PRIMARYKEY ) {
					throw "POR FAVOR REVEJA AS CONSTRAINTS, CONSTRAINT OBRIGATORIA (NOME_DATASERVER, XML OU TAMANHO_PRIMARYKEY) FALTANDO.";
				}
				
				log.info("######### [DSINTEGRAFACILRM] EXECUTANDO PROCESSO DE GRAVACAO");
				var dataset = DatasetBuilder.newDataset();
				dataset.addColumn("RETORNO");
				dataset.addColumn("DATASERVER");
				dataset.addColumn("TAMANHO_PRIMARYKEY");
				dataset.addColumn("RMSCONTEXT");
				dataset.addColumn("XML");
				var result = dcSaveRecord(NOME_DATASERVER, filters.context, usuario, senha, XML);
				log.info("######### [DSINTEGRAFACILRM] OPC 3 - RESULTADO: " + result);
				
				if ( checkIsPK(result, TAMANHO_PRIMARYKEY) ) {
					var linha = new Array();
					linha.push(result.toString());
					linha.push(NOME_DATASERVER);
					linha.push(TAMANHO_PRIMARYKEY);
					linha.push(filters.context);
					linha.push(XML);
					dataset.addRow(linha);
					
					return dataset;
					
				} else {
					throw "NÃO FOI POSSIVEL VALIDAR CHAVE, REGISTRO PODE NÃO TER SIDO SALVO.";
				}
				
			case 4:
				if ( !SENTENCA || !COLIGADA || !APLICACAO || !OBJETO || !CAMPOS ) {
					throw "POR FAVOR REVEJA AS CONSTRAINTS, CONSTRAINT OBRIGATORIA (SENTENCA, COLIGADA,  APLICACAO, OBJETO E CAMPOS) FALTANDO.";
				}
				log.info("######### [DSINTEGRAFACILRM] EXECUTANDO PROCESSO DE CONSULTA SQL");
				OBJETO = "Resultado";
				log.info("######### usuario= " + usuario);
				log.info("######### senha= " + senha);
				log.info("######### SENTENCA= " + SENTENCA); 
				log.info("######### COLIGADA= " + COLIGADA); 
				log.info("######### APLICACAO= " + APLICACAO); 
				log.info("######### PARAMETER= " + PARAMETER); 
				
				var xmlResultados = dcExecuteSQL(usuario, senha, SENTENCA, COLIGADA, APLICACAO, PARAMETER);
				var dataset = DatasetBuilder.newDataset();
				
				if (!xmlResultados[OBJETO][0]) {
					throw "NÃO FORAM ENCONTRADO OS DADOS NA CONSULTA.";
				}
				
				var colunas = [];
				if (CAMPOS.indexOf(",") > -1) {
					colunas = CAMPOS.split(",");
				} else if (CAMPOS.indexOf(";") > -1) {
					colunas = CAMPOS.split(";");
				} else if (CAMPOS.indexOf("&") > -1) {
					colunas = CAMPOS.split("&");
				} else {
					colunas.push(CAMPOS);
				}
				
				for (var i = 0; i < colunas.length; i++) {
					dataset.addColumn(colunas[i]);
				}
				
				log.info("######### [DSINTEGRAFACILRM] PREPARANDO COLUNAS PADRAO: OBJETO, CAMPOS, SENTENCA, COLIGADA, APLICACAO, PARAMETER");
				dataset.addColumn("OBJETO");
				dataset.addColumn("CAMPOS");
				dataset.addColumn("SENTENCA");
				dataset.addColumn("COLIGADA");
				dataset.addColumn("APLICACAO");
				dataset.addColumn("PARAMETER");
				log.info("######### [DSINTEGRAFACILRM] ADICIONANDO LINHAS: ");
				log.info("######### SQLLIMIT " + SQLLIMIT);
				for (var i = 0; i < xmlResultados[OBJETO].length(); i++) {
					var linha = new Array();
					for (var j = 0;j < colunas.length;j++) {
						linha.push(xmlResultados[OBJETO][i][colunas[j]].toString());
					}
					linha.push(OBJETO);
					linha.push(CAMPOS);
					linha.push(SENTENCA);
					linha.push(COLIGADA);
					linha.push(APLICACAO);
					linha.push(PARAMETER);
					dataset.addRow(linha);
					if (SQLLIMIT && i >= SQLLIMIT) {
						break;
					}
				}
				
				log.info("######### [DSINTEGRAFACILRM] DATASET CRIADO COM SUCESSO");
				
				return dataset;
				
			case 5:
				if (!PROCESS || !PARAMETER) {
					throw "POR FAVOR REVEJA AS CONSTRAINTS, CONSTRAINT OBRIGATORIA (PROCESS OU PARAMETER) FALTANDO.";
				}
				
				log.info("######### [DSINTEGRAFACILRM] EXECUTANDO PROCESSO DE FORMULA VISUAL");
				var dataset = DatasetBuilder.newDataset();
				dataset.addColumn("RETORNO");
				dataset.addColumn("PROCESS");
				dataset.addColumn("PARAMETER");
				
				if (XML == 'N') {
					log.info("######### [DSINTEGRAFACILRM] EXECUTANDO SEM XMLPARAMS");
					var result = dcExecuteProcessWithParams(usuario, senha, PROCESS, PARAMETER);
				} else {
					log.info("######### [DSINTEGRAFACILRM] EXECUTANDO COM XMLPARAMS");
					var result = dcExecuteProcessWithXmlParams(usuario, senha, PROCESS, PARAMETER);
				}
				
				if (result != "1") {
					throw "ERRO AO EXERCUTAR FORMULA VISUAL, VERIFIQUE O LOG: " + result;
				}
				log.info("######### [DSINTEGRAFACILRM] OPC 5 - RESULTADO: " + result);
				
				var linha = new Array();
				linha.push(result);
				linha.push(PROCESS);
				linha.push(PARAMETER);
				dataset.addRow(linha);
				
				return dataset;
				
			case 6:
				/*
				 * Alterado por: Alexandre Silva Alterado em: 26/07/2019 Alteração: foi removida a consistencia de filtro e parametro, pois os relatórios podem ter um ou outro ou ter ambos ou apenas não ter nenhum.
				 */
				if (!REPORT || !COLIGADA || !FILE) {
					throw "POR FAVOR REVEJA AS CONSTRAINTS, CONSTRAINT OBRIGATORIA (REPORT, FILE, COLIGADA) FALTANDO.";
				}
				
				if (PARAMETER == undefined) {
