	return(!str || 0 === str.length);
}

/**
 * @description Função para converter XML em JSON, realizada alteração para levar em consideração ou não os atributos e inputar no objeto também os valores dos nós
 * @author David Walsh
 * @source https://davidwalsh.name/convert-xml-json
 */

function parseToJSON (xml, attr) {
	var json = {};
	if (xml.nodeType == 1) {
		if (xml.attributes.length > 0 && attr) {
			for (var j = 0;j < xml.attributes.length;j++) {
				var attribute = xml.attributes.item(j);
				json[attribute.nodeName] = attribute.nodeValue;
			}
		}
		
	} else if (xml.nodeType == 3) {
		json = xml.nodeValue;
	}
	
	if (xml.childNodes.length > 0) {
		for (var i = 0; i < xml.childNodes.length; i++) {
			var item = xml.childNodes.item(i);
			var nodeName = item.nodeName;
			if (typeof (json[nodeName]) == "undefined") {
				if (item.firstChild == null || (item.firstChild && item.firstChild.nodeType == 3)) {
					if (item.firstChild) {
						json[nodeName] = item.firstChild.nodeValue;
					} else {
						json[nodeName] = '';
					}
					
				} else {
					json[nodeName] = this.parseToJSON(item);
				}
				
			} else {
				if (typeof (json[nodeName].push) == "undefined") {
					var old = json[nodeName];
					json[nodeName] = [];
					json[nodeName].push(old);
				}
				json[nodeName].push(this.parseToJSON(item));
			}
		}
	}
	
	return json;
}

function getPasswordUserIntegration () {
	try {
		var sistema = "RM";
		var usuario = "wffluig";
		var cs = new Array();
		cs.push(DatasetFactory.createConstraint("metadata#active", true, true, ConstraintType.MUST));
		cs.push(DatasetFactory.createConstraint("SISTEMA", sistema, sistema, ConstraintType.MUST));
		cs.push(DatasetFactory.createConstraint("USUARIO", usuario, usuario, ConstraintType.MUST));
		var ds = DatasetFactory.getDataset("ds_form_cadastro_de_usuarios_integracao", null, cs, null);
		
		if (ds.rowsCount > 0) {
			var values = {
				USUARIO:ds.getValue(0, 'USUARIO'), 
				SENHA:ds.getValue(0, 'SENHA')
			}
			
			return values;
			
		} else {
			throw "Não foi encontrado nenhum registro no formulário de 'Cadastro de Usuários Integração' para o sistema " + sistema + " e usuário " + usuario;
		}
		
	} catch(e) {
		log.error("|| Erro na função getPasswordUserIntegration do dsIntegraFacilRM: " +e);
		var dataset = DatasetBuilder.newDataset();
		dataset.addColumn("ERRO");
		dataset.addRow(new Array(e));
		return dataset;
	}
